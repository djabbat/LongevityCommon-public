<!DOCTYPE html>
<html lang={Atom.to_string(assigns[:locale] || :en)} dir={if AimWeb.I18n.rtl?(assigns[:locale] || :en), do: "rtl", else: "ltr"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <title><%= AimWeb.I18n.t("app.title", assigns[:locale] || :en) %></title>
    <style>
      :root {
        --bg: #0b0d12;
        --bg-elev: #131722;
        --border: #1f2436;
        --text: #e6e9ef;
        --text-dim: #8b93a7;
        --accent: #6ea3ff;
        --accent-dim: #4a7bd6;
        --good: #4ade80;
        --warn: #fbbf24;
        --bad: #ef4444;
        --crit: #f97316;
      }
      [data-theme="light"] {
        --bg: #fafbfc;
        --bg-elev: #ffffff;
        --border: #e5e7eb;
        --text: #1f2937;
        --text-dim: #6b7280;
        --accent: #2563eb;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        font-size: 15px;
        line-height: 1.55;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3 { color: var(--text); margin-top: 0; }
      h1 { font-size: 1.85rem; font-weight: 700; }
      h2 { font-size: 1.25rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
      h3 { font-size: 1.05rem; font-weight: 600; margin: 0; }

      /* ── Top header ──────────────────────────────────────────── */
      .aim-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 0.7rem 1.5rem;
        background: var(--bg-elev);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .aim-brand {
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--text);
      }
      .aim-brand .logo { color: var(--accent); margin-right: 0.4rem; }
      .aim-nav { display: flex; gap: 1rem; flex-wrap: wrap; }
      .aim-nav a {
        color: var(--text-dim);
        font-size: 0.92rem;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        transition: background 0.15s, color 0.15s;
      }
      .aim-nav a:hover { color: var(--text); background: var(--border); text-decoration: none; }
      .aim-nav a.active { color: var(--accent); background: rgba(110,163,255,0.1); }

      .lang-switcher {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .lang-switcher label { color: var(--text-dim); font-size: 0.85rem; }
      .lang-switcher select {
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.25rem 0.5rem;
        font-size: 0.9rem;
        cursor: pointer;
      }

      /* ── Page container ──────────────────────────────────────── */
      .aim-page {
        max-width: 1080px;
        margin: 2rem auto;
        padding: 0 1.5rem;
      }

      /* ── Landing ─────────────────────────────────────────────── */
      .aim-landing { max-width: 1080px; margin: 0 auto; padding: 1rem 1.5rem 4rem; }
      .hero {
        text-align: center;
        padding: 3.5rem 0 2.5rem;
        border-bottom: 1px solid var(--border);
      }
      .brand-mark {
        font-size: 4rem;
        color: var(--accent);
        line-height: 1;
        margin-bottom: 0.5rem;
      }
      .hero h1 { font-size: 2.4rem; margin: 0.3rem 0 0.7rem; }
      .hero .tagline { color: var(--text-dim); max-width: 720px; margin: 0 auto 2rem; font-size: 1.05rem; }
      .cta-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
      .cta {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        background: var(--bg-elev);
        color: var(--text);
        border: 1px solid var(--border);
        font-weight: 500;
        transition: transform 0.1s, border-color 0.15s;
      }
      .cta:hover { text-decoration: none; border-color: var(--accent); transform: translateY(-1px); }
      .cta.primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }
      .cta.primary:hover { background: var(--accent-dim); border-color: var(--accent-dim); }

      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.2rem;
        margin: 2.5rem 0;
      }
      .feature {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.4rem;
      }
      .feature-icon { font-size: 1.7rem; margin-bottom: 0.6rem; }
      .feature p { color: var(--text-dim); margin: 0; font-size: 0.95rem; line-height: 1.5; }

      .quicknav {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
      }
      .quicknav .card {
        display: block;
        padding: 1.3rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        transition: border-color 0.15s, transform 0.1s;
      }
      .quicknav .card:hover {
        text-decoration: none;
        border-color: var(--accent);
        transform: translateY(-1px);
      }
      .quicknav .card h3 { color: var(--text); margin-bottom: 0.4rem; }
      .quicknav .card p { color: var(--text-dim); margin: 0; font-size: 0.9rem; }

      /* ── Dashboard ───────────────────────────────────────────── */
      .aim-dashboard section { margin-bottom: 2rem; }
      .aim-dashboard ul { list-style: none; padding: 0; }
      .aim-dashboard li {
        padding: 0.6rem 0.9rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        margin-bottom: 0.4rem;
      }
      .status { padding: 0.2rem 0.55rem; border-radius: 999px; font-size: 0.8rem; font-weight: 600; }
      .status-ok, .status-starting { background: rgba(74,222,128,0.15); color: var(--good); }
      .status-warning { background: rgba(251,191,36,0.18); color: var(--warn); }
      .status-down, .status-critical { background: rgba(239,68,68,0.15); color: var(--bad); }
      .phase { font-size: 0.78rem; color: var(--text-dim); }

      /* ── Drug interactions ───────────────────────────────────── */
      .aim-drug-check form {
        background: var(--bg-elev);
        padding: 1.2rem;
        border-radius: 10px;
        border: 1px solid var(--border);
        margin-bottom: 1.5rem;
      }
      .aim-drug-check textarea {
        width: 100%;
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.65rem;
        font-family: inherit;
        font-size: 0.95rem;
        margin-bottom: 0.7rem;
        resize: vertical;
      }
      .aim-drug-check .actions { display: flex; gap: 0.6rem; }
      .aim-drug-check button {
        padding: 0.55rem 1.2rem;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--bg-elev);
        color: var(--text);
        cursor: pointer;
        font-weight: 500;
      }
      .aim-drug-check button[type="submit"] { background: var(--accent); color: #fff; border-color: var(--accent); }
      .aim-drug-check button:disabled { opacity: 0.5; cursor: not-allowed; }
      .drug-list { list-style: none; padding: 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .drug-list li {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        font-size: 0.88rem;
      }
      .findings table { width: 100%; border-collapse: collapse; margin-top: 0.7rem; }
      .findings th, .findings td { text-align: left; padding: 0.5rem 0.7rem; border-bottom: 1px solid var(--border); }
      .findings th { color: var(--text-dim); font-weight: 500; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.04em; }
      .sev-major { color: var(--bad); }
      .sev-moderate { color: var(--warn); }
      .sev-minor { color: var(--text-dim); }
      .report { background: var(--bg-elev); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; white-space: pre-wrap; font-family: ui-monospace, "SF Mono", Monaco, monospace; font-size: 0.85rem; }

      /* ── Settings ────────────────────────────────────────────── */
      .aim-settings .hint { color: var(--text-dim); font-size: 0.9rem; max-width: 720px; }
      .provider-list { list-style: none; padding: 0; }
      .provider-list > li {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.7rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
      }
      .provider-name { min-width: 110px; font-weight: 500; }
      .key-form { display: flex; gap: 0.5rem; flex: 1; }
      .key-form input[type="password"] {
        flex: 1;
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.4rem 0.6rem;
        font-family: ui-monospace, monospace;
      }
      .key-form button, .clear, .clear-all {
        padding: 0.4rem 0.9rem;
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.88rem;
      }
      .clear { color: var(--text-dim); }
      .clear-all { margin-top: 0.8rem; color: var(--bad); border-color: var(--bad); }
      .status-ok { padding: 0.5rem 0.8rem; border-radius: 6px; }
      .status-error { padding: 0.5rem 0.8rem; border-radius: 6px; background: rgba(239,68,68,0.15); color: var(--bad); }

      /* ── Footer ──────────────────────────────────────────────── */
      .aim-footer {
        max-width: 1080px;
        margin: 3rem auto 1.5rem;
        padding: 1.5rem 1.5rem 0;
        border-top: 1px solid var(--border);
        color: var(--text-dim);
        font-size: 0.85rem;
        text-align: center;
      }
      .aim-footer a { color: var(--text-dim); }
    </style>
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
