<!DOCTYPE html>
<html lang="en" class="h-full bg-white">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <.live_title suffix=" · Proteostasis">
      <%= assigns[:page_title] || "Dashboard" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
  </head>
  <body class="h-full">
    <div class="min-h-full">
      <nav class="bg-gray-800">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <img
                  class="h-8 w-8"
                  src={~p"/images/logo.svg"}
                  alt="Proteostasis Counter #5"
                />
              </div>
              <div class="hidden md:block">
                <div class="ml-10 flex items-baseline space-x-4">
                  <.link
                    navigate={~p"/"}
                    class={["rounded-md px-3 py-2 text-sm font-medium",
                      @current_page == :dashboard && "bg-gray-900 text-white",
                      @current_page != :dashboard && "text-gray-300 hover:bg-gray-700 hover:text-white"]}
                  >
                    Dashboard
                  </.link>
                  <.link
                    href="https://commonhealth.mit.edu"
                    target="_blank"
                    class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
                  >
                    LongevityCommon
                  </.link>
                </div>
              </div>
            </div>
            <div class="hidden md:block">
              <div class="ml-4 flex items-center md:ml-6">
                <span class="rounded-md px-3 py-2 text-sm font-medium text-gray-300">
                  Counter #5: Proteostasis Collapse
                </span>
              </div>
            </div>
          </div>
        </div>
      </nav>
      <main>
        <div class="mx-auto max-w-7xl py-6 sm:px-6 lg:px-8">
          <%= @inner_content %>
        </div>
      </main>
    </div>
  </body>
</html>